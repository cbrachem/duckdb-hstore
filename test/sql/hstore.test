# name: test/sql/hstore.test
# description: test hstore extension
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT hstore_get('a=>b', 'a');
----
Catalog Error: Scalar Function with name hstore_get does not exist!

# Require statement will ensure this test is run with this extension loaded
require hstore

statement ok
PRAGMA enable_verification

# Confirm the extension works
query I
SELECT hstore_get('a=>b', 'a');
----
b

# --- hstore_get: basic lookups ---

query I
SELECT hstore_get('aa=>b, c=>d, b=>16', 'c');
----
d

query I
SELECT hstore_get('aa=>b, c=>d, b=>16', 'b');
----
16

query I
SELECT hstore_get('aa=>b, c=>d, b=>16', 'aa');
----
b

# --- hstore_get: duplicate key, last one wins ---

query I
SELECT hstore_get('a=>b, a=>c', 'a');
----
c

# --- hstore_get: key not found returns NULL ---

query I
SELECT hstore_get('aa=>b, c=>d, b=>16', 'gg');
----
NULL

# --- hstore_get: empty hstore returns NULL ---

query I
SELECT hstore_get('', 'x');
----
NULL

# --- hstore_get: hstore NULL value returns NULL ---

query I
SELECT hstore_get('aa=>NULL, c=>d, b=>16', 'aa');
----
NULL

query I
SELECT hstore_get('aa=>NuLl, c=>d', 'aa');
----
NULL

# --- hstore_get: quoted "NULL" is NOT null, it's a literal string ---

query I
SELECT hstore_get('aa=>"NuLl", c=>d', 'aa');
----
NuLl

# --- hstore_get: quoted key with space ---

query I
SELECT hstore_get('"a key" =>1, b => t', 'a key');
----
1

# --- hstore_get: quoted value with escaped characters ---

query I
SELECT hstore_get('k=>"val \"quoted\""', 'k');
----
val "quoted"

# --- hstore_get: whitespace variations ---

query I
SELECT hstore_get(' a => b ', 'a');
----
b

query I
SELECT hstore_get('a=>b', 'a');
----
b

query I
SELECT hstore_get(' a=>b', 'a');
----
b

query I
SELECT hstore_get('a =>b', 'a');
----
b

query I
SELECT hstore_get('a=> b', 'a');
----
b

query I
SELECT hstore_get('a=>b ', 'a');
----
b

# --- hstore_get: NULL input propagation (DEFAULT_NULL_HANDLING) ---

query I
SELECT hstore_get(NULL, 'a');
----
NULL

query I
SELECT hstore_get('a=>1', NULL);
----
NULL

# --- hstore_get: backslash escaping in unquoted tokens ---

query I
SELECT hstore_get('\=a=>q=w', '=a');
----
q=w

# --- hstore_get: empty string key (quoted) ---

query I
SELECT hstore_get('""=>1', '');
----
1

# --- hstore_get: error cases ---

statement error
SELECT hstore_get(' =>null', 'x');
----
Invalid Input Error

statement error
SELECT hstore_get('a=b', 'x');
----
Invalid Input Error

statement error
SELECT hstore_get('aa=>"', 'x');
----
Invalid Input Error
